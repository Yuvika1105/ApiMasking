{
  "name": "Dynamic Data Masking Sandbox",
  // More info: https://containers.dev/guide/dockerfile
  "image": "mcr.microsoft.com/devcontainers/python:1-3.11-bookworm",
  "customizations": {
    "codespaces": {
      "openFiles": [
        "README.md",
        "main.py"
      ]
    },
    "vscode": {
      "settings": {},
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance"
      ]
    }
  },
  "updateContentCommand": "[ -f requirements.txt ] && pip3 install --user -r requirements.txt; echo '✅ Packages installed and Requirements met'",
  "postAttachCommand": {
    "server": "uvicorn main:app --host 0.0.0.0 --port 8000"
  },
  "portsAttributes": {
    "8000": {
      "label": "SafeGuard App",
      "onAutoForward": "openPreview"
    }
  },
  "forwardPorts": [
    8000
  ]
}